{
  "manifest_version": 3,
  "name": "WordMap Screen Translator",
  "version": "1.3.0",
  "description": "Capture text on any page with freehand or rectangle selection, run OCR, and translate it with AI.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WordMap",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "i18n.js",
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "commands": {
    "toggle-draw-mode": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Start freehand capture"
    },
    "toggle-rect-mode": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Alt+R"
      },
      "description": "Start rectangle capture"
    }
  }
}