{
  "manifest_version": 3,
  "name": "WordMap 圈选翻译",
  "version": "1.0",
  "description": "支持铅笔画圈与矩形框选，利用视觉/OCR技术实现万物皆可抠图翻译。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "commands": {
    "toggle-draw-mode": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "开启/关闭铅笔画圈模式"
    },
    "toggle-rect-mode": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Alt+R"
      },
      "description": "开启/关闭矩形框选模式"
    }
  }
}
