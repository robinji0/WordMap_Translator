{
  "manifest_version": 3,
  "name": "WordMap 圈选翻译",
  "version": "1.3",
  "description": "支持自由圈选与矩形框选，使用 OCR + AI 进行网页区域翻译。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "i18n.js",
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "commands": {
    "toggle-draw-mode": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "开启/关闭自由圈选模式"
    },
    "toggle-rect-mode": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Alt+R"
      },
      "description": "开启/关闭矩形框选模式"
    }
  }
}
